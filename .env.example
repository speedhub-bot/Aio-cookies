# ── Telegram credentials ────────────────────────────────────
BOT_TOKEN=8699961104:AAG9MszBckATxB_hN2Cg8Zjj4f8qYwkFnaU
# Required. From @BotFather

# Optional. Defaults to Telegram Desktop's public api_id/api_hash so
# the bot works out-of-the-box. Override if you have your own.
API_ID=2040
API_HASH=b18441a1ff607e10a989891a5462e627

# Optional. Numeric Telegram user ID that gets notified about errors.
ADMIN_ID=5944410248

# ── Bot behaviour ───────────────────────────────────────────
# Telegram bot API caps downloads at 20 MB. Don't raise unless you're
# also wiring pyrofork in front of the document download path.
MAX_FILE_BYTES=20971520
MAX_THREADS=10
JOB_TIMEOUT_SECONDS=600

# Optional HTTP(S) proxy applied to every scanner request.
# Example: http://user:pass@host:port
DEFAULT_PROXY=

# Default ON/OFF state for hit notifications on first contact.
# Per-user override lives in bot_data/settings.json.
HIT_NOTIFICATIONS_DEFAULT=false

# ── Paths ───────────────────────────────────────────────────
DATA_DIR=bot_data
LOG_FILE=bot.log
TEMP_DIR=/tmp/aiocookies-bot
